generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String?
  createdAt   DateTime     @default(now())
  contractors Contractor[]
  projects    Project[]
}

model Project {
  id        String    @id @default(uuid())
  userId    String
  name      String
  location  String?
  tenderRef String?
  type      String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  expenses  Expense[]
  user      User      @relation(fields: [userId], references: [id])
  salaries  Salary[]
  tenders   Tender[]
  workers   Worker[]
}

model Worker {
  id         String    @id @default(uuid())
  projectId  String
  userId     String
  name       String
  role       String?
  dailyWage  Float?
  joinedDate DateTime?
  createdAt  DateTime  @default(now())
  salaries   Salary[]
  project    Project   @relation(fields: [projectId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  projectId   String
  userId      String
  date        DateTime
  category    String
  description String?
  amount      Float
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])
}

model Tender {
  id            String    @id @default(uuid())
  projectId     String?
  userId        String
  title         String
  tenderValue   Float?
  status        String    @default("submitted")
  submittedDate DateTime?
  createdAt     DateTime  @default(now())
  project       Project?  @relation(fields: [projectId], references: [id])
}

model Salary {
  id        String    @id @default(uuid())
  projectId String
  workerId  String
  userId    String
  month     String
  amount    Float
  paidOn    DateTime?
  isPaid    Boolean   @default(false)
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id])
  worker    Worker    @relation(fields: [workerId], references: [id])
}

model Contractor {
  id        String   @id @default(uuid())
  userId    String
  name      String
  specialty String
  rating    Float    @default(0)
  contact   String?
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
