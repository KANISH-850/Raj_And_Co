generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String?
  role        String       @default("user") // "admin", "user"
  isApproved  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  contractors      Contractor[]
  projects         Project[]
  selectedTenders  SelectedTender[]
  documents        Document[]
}

model Project {
  id        String    @id @default(uuid())
  userId    String
  name      String
  location  String?
  tenderRef String?
  type      String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  expenses  Expense[]
  user      User      @relation(fields: [userId], references: [id])
  salaries  Salary[]
  tenders   Tender[]
  workers   Worker[]
  documents Document[]
  actualBudget Float?
}

model Worker {
  id         String    @id @default(uuid())
  projectId  String
  userId     String
  name       String
  role       String?
  dailyWage  Float?
  joinedDate DateTime?
  createdAt  DateTime  @default(now())
  salaries   Salary[]
  project    Project   @relation(fields: [projectId], references: [id])
  documents  Document[]
}

model Expense {
  id          String   @id @default(uuid())
  projectId   String
  userId      String
  date        DateTime
  category    String
  description String?
  amount      Float
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])
}

model Tender {
  id            String    @id @default(uuid())
  projectId     String?
  userId        String
  title         String
  tenderValue   Float?
  status        String    @default("submitted")
  submittedDate DateTime?
  createdAt     DateTime  @default(now())
  project       Project?  @relation(fields: [projectId], references: [id])
  documents     Document[]
}

model Salary {
  id        String    @id @default(uuid())
  projectId String
  workerId  String
  userId    String
  month     String
  amount    Float
  paidOn    DateTime?
  isPaid    Boolean   @default(false)
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id])
  worker    Worker    @relation(fields: [workerId], references: [id])
}

model Contractor {
  id        String   @id @default(uuid())
  userId    String
  name      String
  specialty String
  rating    Float    @default(0)
  contact   String?
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  name      String
  type      String
  url       String
  category  String?  // 'tender', 'project', 'worker', 'legal'
  projectId String?
  tenderId  String?
  workerId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  tender    Tender?  @relation(fields: [tenderId], references: [id])
  worker    Worker?  @relation(fields: [workerId], references: [id])
}

enum TenderStatus {
  SELECTED
  DOCUMENT_PENDING
  SUBMITTED
  WON
  LOST
  CLOSED
}

model SelectedTender {
  id             String       @id @default(uuid())
  userId         String
  tenderNumber   String
  title          String
  department     String?
  estimatedValue Float?
  selectedDate   DateTime     @default(now())
  deadline       DateTime?
  status         TenderStatus @default(SELECTED)
  priority       String       @default("medium") // high, medium, low
  source         String?
  notes          String?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
}
