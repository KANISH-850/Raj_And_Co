# ─── API BASE URL ───────────────────────────────────────────
# DEV:  http://localhost:5000/api
# PROD: https://raj-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# ─── SUPABASE AUTH ──────────────────────────────────────────
# Find these in Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=...
VITE_SUPABASE_ANON_KEY=...
